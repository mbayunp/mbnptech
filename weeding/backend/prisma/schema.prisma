generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            BigInt         @id @default(autoincrement())
  name          String         @db.VarChar(255)
  email         String         @unique(map: "email") @db.VarChar(255)
  password      String         @db.VarChar(255)
  phone         String?        @db.VarChar(50)
  avatar        String?        @db.VarChar(255)
  role          users_role?    @default(user)
  isVerified    Boolean?       @default(false) @map("is_verified")
  createdAt     DateTime       @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt     DateTime       @default(now()) @db.Timestamp(0) @map("updated_at")
  invitations   Invitation[]
  payments      Payment[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    BigInt   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @db.Timestamp(0) @map("created_at")

  @@map("refresh_tokens")
}

model Template {
  id          BigInt            @id @default(autoincrement())
  name        String            @db.VarChar(255)
  slug        String            @unique(map: "slug") @db.VarChar(255)
  category    String?           @db.VarChar(100)
  thumbnail   String?           @db.Text
  previewUrl  String?           @db.Text @map("preview_url")
  isPremium   Boolean?          @default(false) @map("is_premium")
  price       Decimal?          @default(0.00) @db.Decimal(12, 2)
  status      templates_status? @default(active)
  createdAt   DateTime          @default(now()) @db.Timestamp(0) @map("created_at")
  invitations Invitation[]

  @@map("templates")
}

model Invitation {
  id            BigInt              @id @default(autoincrement())
  userId        BigInt              @map("user_id")
  templateId    BigInt              @map("template_id")
  slug          String              @unique(map: "slug") @db.VarChar(255)
  subdomain     String              @unique(map: "subdomain") @db.VarChar(255)
  title         String?             @db.VarChar(255)
  welcomeText   String?             @db.Text @map("description")
  groomName     String?             @db.VarChar(255) @map("groom_name")
  brideName     String?             @db.VarChar(255) @map("bride_name")
  weddingDate   DateTime?           @db.Date @map("event_date")
  eventTime     DateTime?           @db.Time(0) @map("event_time")
  address       String?             @db.Text @map("location") // Map 'address' TS to 'location' DB
  mapUrl        String?             @db.Text @map("maps_url") // Map 'mapUrl' TS to 'maps_url' DB
  musicUrl      String?             @db.Text @map("music_url")
  coverImage    String?             @db.Text @map("cover_image")
  themeColor    String?             @db.VarChar(100) @map("theme")
  isPublished   Boolean?            @default(true) @map("is_active")
  isPremium     Boolean?            @default(false) @map("is_premium")
  createdAt     DateTime            @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt     DateTime            @default(now()) @db.Timestamp(0) @map("updated_at")
  analytics     Analytics[]
  galleries     Gallery[]
  gifts         Gift[]
  guests        Guest[]
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "invitations_ibfk_1")
  template      Template            @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "invitations_ibfk_2")
  payments      Payment[]
  rsvps         Rsvp[]
  stories       Story[]
  themeSettings ThemeSettings?
  sections      InvitationSection[]

  @@index([templateId], map: "template_id")
  @@index([userId], map: "user_id")
  @@map("invitations")
}

model ThemeSettings {
  id              BigInt     @id @default(autoincrement())
  primaryColor    String     @default("#4f46e5") @map("primary_color")
  secondaryColor  String     @default("#ec4899") @map("secondary_color")
  fontFamily      String     @default("sans") @map("font_family")
  animationStyle  String     @default("fade") @map("animation_style")
  backgroundStyle String     @default("solid") @map("background_style")
  invitation      Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitationId    BigInt     @unique @map("invitation_id")

  @@map("theme_settings")
}

model InvitationSection {
  id           BigInt     @id @default(autoincrement())
  sectionName  String     @map("section_name") // "hero", "bride", "gallery", "countdown", "story", "gift", "rsvp", "maps", "music"
  isEnabled    Boolean    @default(true) @map("is_enabled")
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  invitationId BigInt     @map("invitation_id")

  @@unique([invitationId, sectionName])
  @@map("invitation_sections")
}

model Gallery {
  id           BigInt     @id @default(autoincrement())
  invitationId BigInt     @map("invitation_id")
  imageUrl     String     @db.Text @map("image_url")
  sortOrder    Int?       @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @db.Timestamp(0) @map("created_at")
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "galleries_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("galleries")
}

model Story {
  id           BigInt     @id @default(autoincrement())
  invitationId BigInt     @map("invitation_id")
  title        String?    @db.VarChar(255)
  content      String?    @db.Text @map("description") // Map 'content' TS to 'description' DB
  date         DateTime?  @db.Date @map("story_date")  // Map 'date' TS to 'story_date' DB
  imageUrl     String?    @db.Text @map("image_url")
  createdAt    DateTime   @default(now()) @db.Timestamp(0) @map("created_at")
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "stories_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("stories")
}

model Guest {
  id           BigInt     @id @default(autoincrement())
  invitationId BigInt     @map("invitation_id")
  name         String?    @db.VarChar(255)
  phone        String?    @db.VarChar(50)
  address      String?    @db.VarChar(100) @map("category")
  code         String?    @db.VarChar(255) @map("unique_code") // Map 'code' TS to 'unique_code' DB
  qrToken      String?    @db.Text @map("qr_code")              // Map 'qrToken' TS to 'qr_code' DB
  isAttended   Boolean?   @default(false) @map("is_attended")
  createdAt    DateTime   @default(now()) @db.Timestamp(0) @map("created_at")
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "guests_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("guests")
}

model Rsvp {
  id           BigInt                   @id @default(autoincrement())
  invitationId BigInt                   @map("invitation_id")
  name         String?                  @db.VarChar(255) @map("guest_name") // Map 'name' TS to 'guest_name' DB
  phone        String?                  @db.VarChar(50)
  attendance   rsvps_attendance_status? @default(ragu) @map("attendance_status") // Map 'attendance' TS enum to 'attendance_status' DB
  guestCount   Int?                     @default(1) @map("guest_count")
  message      String?                  @db.Text
  createdAt    DateTime                 @default(now()) @db.Timestamp(0) @map("created_at")
  invitations  Invitation               @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "rsvps_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("rsvps")
}

model Analytics {
  id           BigInt     @id @default(autoincrement())
  invitationId BigInt     @map("invitation_id")
  ipAddress    String?    @db.VarChar(100) @map("visitor_ip")
  device       String?    @db.VarChar(100)
  browser      String?    @db.VarChar(100)
  country      String?    @db.VarChar(100)
  city         String?    @db.VarChar(100)
  createdAt    DateTime   @default(now()) @db.Timestamp(0) @map("visited_at")
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "analytics_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("analytics")
}

model Gift {
  id            BigInt     @id @default(autoincrement())
  invitationId  BigInt     @map("invitation_id")
  bankName      String?    @db.VarChar(255) @map("bank_name")
  accountName   String?    @db.VarChar(255) @map("account_name")
  accountNumber String?    @db.VarChar(255) @map("account_number")
  qrisUrl       String?    @db.Text @map("qris_url")
  createdAt     DateTime   @default(now()) @db.Timestamp(0) @map("created_at")
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "gifts_ibfk_1")

  @@index([invitationId], map: "invitation_id")
  @@map("gifts")
}

model Payment {
  id            BigInt           @id @default(autoincrement())
  userId        BigInt           @map("user_id")
  invitationId  BigInt           @map("invitation_id")
  paymentMethod String?          @map("payment_method") @db.VarChar(100)
  amount        Decimal?         @db.Decimal(12, 2)
  status        payments_status? @default(pending)
  transactionId String?          @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime?        @map("paid_at") @db.Timestamp(0)
  createdAt     DateTime         @default(now()) @db.Timestamp(0) @map("created_at")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_1")
  invitation    Invitation       @relation(fields: [invitationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_2")

  @@index([invitationId], map: "invitation_id")
  @@index([userId], map: "user_id")
  @@map("payments")
}

enum rsvps_attendance_status {
  hadir
  tidak_hadir
  ragu
}

enum payments_status {
  pending
  paid
  failed
}

enum users_role {
  admin
  user
}

enum templates_status {
  active
  inactive
}
